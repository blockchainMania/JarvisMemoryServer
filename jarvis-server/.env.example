# Postgres connection (matches docker-compose, port 5433 to avoid clash with system pg)
DATABASE_URL=postgresql://jarvis:jarvis_dev_password@localhost:5433/jarvis

# API key — clients must send this in X-API-Key header. Rotate before production.
API_KEY=dev-secret-change-me

HOST=0.0.0.0
PORT=8000

# Embedding model — both are 1024-dim, drop-in swappable.
#   nlpai-lab/KURE-v1   → Korean-focused (BGE-M3 한국어 파인튜닝)
#   BAAI/bge-m3         → multilingual baseline
EMBEDDING_MODEL=nlpai-lab/KURE-v1
EMBEDDING_DIM=1024
FACE_EMBEDDING_DIM=512

# cpu | cuda | mps
EMBEDDING_DEVICE=cpu

# OpenAI meeting transcription/summarization (server-side only)
OPENAI_API_KEY=
# GPT_API_KEY is also accepted as a backward-compatible alias.
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_SUMMARY_MODEL=gpt-4.1-mini
OPENAI_REASONING_EFFORT=low
